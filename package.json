{
  "name": "vibe-yt-karaoke-tool",
  "productName": "Vibe YT Karaoke Tool",
  "private": true,
  "version": "1.0.0",
  "description": "Professional YouTube Karaoke Downloader and Management Tool",
  "author": "KirkNetworks, LLC",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:binaries": "node scripts/download-binaries.js",
    "electron:dev": "electron-forge start",
    "electron:build": "electron-forge make",
    "electron:build:all": "electron-forge make",
    "postinstall": "npm run build:binaries",
    "build:ci": "npm run package && electron-builder --publish always"
  },
  "dependencies": {
    "@rsuite/icons": "^1.4.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "ffbinaries": "^1.1.6",
    "lucide-react": "^1.17.0",
    "nedb-promises": "^6.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rsuite": "^6.1.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.kirknetworks.vibe",
    "productName": "Vibe YT Karaoke Tool",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kirkphillip605",
        "repo": "Vibe-Youtube-Downloader"
      }
    ],
    "files": [
      ".vite/**/*",
      "package.json"
    ],
    "extraResources": [
      "bin/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "license": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "asar": true
  }
}
